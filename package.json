{
  "name": "supabase-backend",
  "version": "2.0.0",
  "description": "Supabase Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "audit:introspect": "node audit_tooling/run_all_introspection.js",
    "audit:parse": "node audit_tooling/parse_schema.js",
    "audit:diff": "node audit_tooling/diff_engine.js",
    "audit": "npm run audit:introspect && npm run audit:parse && npm run audit:diff",
    "audit:report": "node audit_tooling/generate_report.js",
    "audit:sync": "node audit_tooling/update_schema_sql.js",
    "db:verify": "node db.js"
  },
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.90.1",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^3.3.2",
    "openai": "^6.17.0",
    "pg": "^8.20.0",
    "pino": "^9.9.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
